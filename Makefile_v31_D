# ── Compiler & Flags ─────────────────────────────────────────────────
CC      := gcc
CFLAGS  := -O3 -std=c11 -Wall -Wextra -pthread -march=native

# ── Quelldateien ─────────────────────────────────────────────────────
MEISTER_SRC   := MBUhcsMasterpiece_v31_A.c
GUI_PY        := MBSysteme_v31_E.py

# ── Ausgabe ──────────────────────────────────────────────────────────
MEISTER_BIN   := mb_meisterwerk
UHCS_LINK     := uhcs

# ── Installationspfade ───────────────────────────────────────────────
PREFIX    := /usr/local
BINDIR    := $(PREFIX)/bin

# ── Konstanten (UNANTASTBAR – Regelwerk §1) ──────────────────────────
SIGMA       := 568
MEIKEL_PRIM := 331
ALPHA_INV   := 137
VERSION     := 31.0

# ══════════════════════════════════════════════════════════════════════
#  TARGETS
# ══════════════════════════════════════════════════════════════════════

.PHONY: all clean test fuzz gui install help build-meisterwerk benchmark

